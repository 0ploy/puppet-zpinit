{
  "name": "zeroploy-zpinit",
  "version": "0.3.0",
  "author": "ZeroPloy",
  "summary": "Manage zpinit services: a zpctl service provider plus TOML config management",
  "license": "MIT",
  "source": "https://github.com/0ploy/puppet-zpinit",
  "project_page": "https://github.com/0ploy/puppet-zpinit",
  "issues_url": "https://github.com/0ploy/puppet-zpinit/issues",
  "dependencies": [
    {
      "name": "puppetlabs/stdlib",
      "version_requirement": ">= 5.0.0 < 10.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Ubuntu",
      "operatingsystemrelease": [ "22.04", "24.04" ]
    },
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": [ "11", "12" ]
    },
    {
      "operatingsystem": "Alpine",
      "operatingsystemrelease": [ "3" ]
    },
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": [ "8", "9" ]
    }
  ],
  "requirements": [
    {
      "name": "puppet",
      "version_requirement": ">= 6.0.0 < 9.0.0"
    }
  ],
  "tags": ["zpinit", "zpctl", "service", "provider", "supervisor", "docker", "container"]
}
